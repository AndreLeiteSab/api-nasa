# NASA API key — get yours at https://api.nasa.gov/
# DEMO_KEY works but is heavily rate-limited (30 req/hour, 50 req/day).
NASA_API_KEY=DEMO_KEY

# CORS origins allowed to call this API (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTP client tuning
REQUEST_TIMEOUT=30
MAX_CONNECTIONS=50
